{
  "name": "phototag-ui",
  "version": "0.0.0",
  "private": true,
  "description": "esbuild bundler for the phototag single-page UI (static/src/*.js -> static/ui.js).",
  "scripts": {
    "build": "esbuild static/src/main.js --bundle --outfile=static/ui.js --target=es2020 --format=iife --legal-comments=none",
    "watch": "esbuild static/src/main.js --bundle --outfile=static/ui.js --target=es2020 --format=iife --legal-comments=none --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
